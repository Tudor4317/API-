generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}


model UserData{
userId String @id @default(uuid())
username String  @unique
email String @unique
password String
salt String
description String?
refreshtoken String?
artefacts Artefacts[]

@@map("users")

}

 model Artefacts{
 artefactId String @id @default(uuid())
 artefact String 
 user UserData @relation(fields: [userId], references: [userId])
 userId String
 isPublic Boolean
 description String?
 date String
 @@map("artefacts")
 }





