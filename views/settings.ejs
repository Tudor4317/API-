<!DOCTYPE html>
<html>
    <head>
        <title>Settings</title>
    </head>
    <body>
<header>
    <h1>Settings</h1>
</header>
       <main>
            <div class = "delete-account">
            <button><a href="/settings/change-email">Delete Account</a></button>
            </div>
        <form action="/settings/change-password" method="POST">
               <label> Change Password</label>
                <input id="password" name="password" placeholder="password" type="password" />
                <button type="submit">Submit</button>
        </form>
            <form action="/settings/change-email" method="POST">
               <label> Change Email</label>
                <input id="email" name="email" placeholder="new email" type="text" />
                <button type="submit">Submit</button>
        </form>
        </main>
    </body>

</html